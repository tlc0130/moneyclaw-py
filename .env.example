# === MoneyClaw Configuration ===

# -- Telegram Bot --
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# -- LLM Providers (仅需配置 API Key，系统自动发现可用模型) --
# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=your_openai_key

# Anthropic (Claude 3 Opus/Sonnet/Haiku)
ANTHROPIC_API_KEY=your_anthropic_key

# DeepSeek (deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=your_deepseek_key

# Groq (Llama, Mixtral 等高速模型)
GROQ_API_KEY=your_groq_key

# Google Gemini
GOOGLE_API_KEY=your_google_key

# Moonshot (月之暗面 / Kimi)
MOONSHOT_API_KEY=your_moonshot_key

# Ollama (本地模型，无需API Key)
OLLAMA_BASE_URL=http://localhost:11434

# -- 智能路由配置 --
# 每日LLM预算上限 (USD)，达到后自动降级到最便宜模型
DAILY_LLM_BUDGET=5.0

# 预算警告阈值 (0.0-1.0)，超过此比例进入谨慎模式
BUDGET_CAUTION_THRESHOLD=0.6

# 是否启用自动降级
ENABLE_AUTO_DOWNGRADE=true

# -- Trading (optional) --
# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# -- Risk Limits --
# MAX_TRADE_AMOUNT=50
# MAX_DAILY_LOSS=100
# APPROVAL_THRESHOLD=50

# -- Database --
# DB_PATH=./data/moneyclaw.db

# -- Web Dashboard --
# WEB_PORT=8080
# WEB_HOST=0.0.0.0
