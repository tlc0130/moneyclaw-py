# === MoneyClaw Configuration ===

# -- Telegram Bot --
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# -- LLM Providers --
# Layer 1: Ollama (local, free) - no key needed
OLLAMA_BASE_URL=http://localhost:11434

# Layer 2: Cheap API providers
DEEPSEEK_API_KEY=your_deepseek_key
GROQ_API_KEY=your_groq_key

# Layer 3: Premium providers (used sparingly)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# -- Trading (optional) --
# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# -- Risk Limits --
# MAX_TRADE_AMOUNT=50
# MAX_DAILY_LOSS=100
# APPROVAL_THRESHOLD=50

# -- Database --
# DB_PATH=./data/moneyclaw.db

# -- Web Dashboard --
# WEB_PORT=8080
# WEB_HOST=0.0.0.0
